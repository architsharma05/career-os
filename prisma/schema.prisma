generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkPreference {
  REMOTE
  HYBRID
  ONSITE
  FLEXIBLE
}

enum ApplicationStatus {
  SAVED
  INTERESTED
  OUTREACH_STARTED
  APPLIED
  RECRUITER_SCREEN
  TECHNICAL_INTERVIEW
  FINAL_ROUND
  OFFER
  REJECTED
  ARCHIVED
}

enum RecommendedAction {
  APPLY_NOW
  NETWORK_FIRST
  SAVE_FOR_LATER
  SKIP
  IMPROVE_RESUME_FIRST
}

model User {
  id             String           @id @default(cuid())
  name           String
  email          String           @unique
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  resumeProfile  ResumeProfile?
  searchProfiles SearchProfile[]
  companies      Company[]
  jobs           Job[]
  applications   Application[]
  contacts       Contact[]
  notes          Note[]
  reminders      Reminder[]
  drafts         GeneratedDraft[]
}

model ResumeProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  fullName       String
  email          String
  location       String?
  resumeText     String
  education      Json
  skills         Json
  projects       Json
  experience     Json
  certifications Json
  links          Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SearchProfile {
  id                String        @id @default(cuid())
  userId            String
  name              String
  targetRole        String
  relatedRoles      Json
  experienceLevel   String
  industries        Json
  locations         Json
  workPreference    WorkPreference
  targetCompanies   Json
  salaryMin         Int?
  salaryMax         Int?
  requiredSkills    Json
  preferredSkills   Json
  excludedKeywords  Json
  jobSearchGoal     String
  scoringPriorities Json
  isActive          Boolean       @default(false)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobMatches        JobMatch[]
  applications      Application[]
}

model RoleTemplate {
  id               String   @id @default(cuid())
  name             String   @unique
  description      String
  relatedTitles    Json
  keywords         Json
  coreSkills       Json
  preferredSkills  Json
  commonIndustries Json
  scoringHints     Json
  interviewTopics  Json
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Company {
  id              String        @id @default(cuid())
  userId          String
  name            String
  website         String?
  industry        String?
  size            String?
  location        String?
  notes           String?
  isTargetCompany Boolean       @default(false)
  priority        String        @default("medium")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs            Job[]
  contacts        Contact[]
  notesList       Note[]
  reminders       Reminder[]
}

model Job {
  id              String        @id @default(cuid())
  userId          String
  companyId       String?
  title           String
  url             String?
  source          String
  location        String?
  workPreference  WorkPreference
  salaryMin       Int?
  salaryMax       Int?
  employmentType  String?
  experienceLevel String?
  description     String
  requiredSkills  Json
  preferredSkills Json
  dateFound       DateTime      @default(now())
  deadline        DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  company         Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  matches         JobMatch[]
  applications    Application[]
  notes           Note[]
  reminders       Reminder[]
  drafts          GeneratedDraft[]
}

model JobMatch {
  id                       String            @id @default(cuid())
  jobId                    String
  searchProfileId          String
  matchScore               Int
  roleFitScore             Int
  skillMatchScore          Int
  experienceMatchScore     Int
  locationMatchScore       Int
  careerGoalScore          Int
  strengths                Json
  gaps                     Json
  missingKeywords          Json
  suggestedResumeKeywords  Json
  recommendedNextAction    RecommendedAction
  outreachAngle            String
  shouldApply              Boolean
  reasonSummary            String
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt
  job                      Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  searchProfile            SearchProfile     @relation(fields: [searchProfileId], references: [id], onDelete: Cascade)

  @@unique([jobId, searchProfileId])
}

model Application {
  id                 String            @id @default(cuid())
  userId             String
  jobId              String
  searchProfileId    String?
  status             ApplicationStatus @default(SAVED)
  resumeVersion      String?
  coverLetterDraft   String?
  appliedDate        DateTime?
  nextFollowUpDate   DateTime?
  interviewDate      DateTime?
  rejectionReason    String?
  offerDetails       String?
  notes              String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  job                Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  searchProfile      SearchProfile?    @relation(fields: [searchProfileId], references: [id], onDelete: SetNull)
  notesList          Note[]
  reminders          Reminder[]
  drafts             GeneratedDraft[]
}

model Contact {
  id               String           @id @default(cuid())
  userId           String
  companyId        String?
  name             String
  title            String?
  email            String?
  linkedinUrl      String?
  relationshipType String
  source           String?
  status           String           @default("active")
  lastContactedDate DateTime?
  nextFollowUpDate DateTime?
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  company          Company?         @relation(fields: [companyId], references: [id], onDelete: SetNull)
  notesList        Note[]
  reminders        Reminder[]
  drafts           GeneratedDraft[]
}

model Note {
  id            String       @id @default(cuid())
  userId        String
  jobId         String?
  companyId     String?
  contactId     String?
  applicationId String?
  content       String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  job           Job?         @relation(fields: [jobId], references: [id], onDelete: Cascade)
  company       Company?     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact       Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  application   Application? @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model Reminder {
  id            String       @id @default(cuid())
  userId        String
  jobId         String?
  companyId     String?
  contactId     String?
  applicationId String?
  title         String
  description   String?
  dueDate       DateTime
  type          String
  isCompleted   Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  job           Job?         @relation(fields: [jobId], references: [id], onDelete: Cascade)
  company       Company?     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact       Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  application   Application? @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model GeneratedDraft {
  id            String       @id @default(cuid())
  userId        String
  jobId         String?
  contactId     String?
  applicationId String?
  type          String
  title         String
  content       String
  aiMetadata    Json
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  job           Job?         @relation(fields: [jobId], references: [id], onDelete: Cascade)
  contact       Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  application   Application? @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}
